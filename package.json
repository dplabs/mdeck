{
	"name": "mdeck",
	"version": "0.17.1",
	"description": "A modern Markdown slideshow library, compatible with remark slide decks",
	"type": "module",
	"main": "./dist/mdeck.umd.cjs",
	"module": "./dist/mdeck.js",
	"exports": {
		".": {
			"import": "./dist/mdeck.js",
			"require": "./dist/mdeck.umd.cjs"
		}
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src --ext .ts",
		"prepare": "husky",
		"release:patch": "npm version patch -m 'chore: bump version to %s'",
		"release:minor": "npm version minor -m 'chore: bump version to %s'",
		"release:major": "npm version major -m 'chore: bump version to %s'"
	},
	"dependencies": {
		"eventemitter3": "^5.0.1",
		"highlight.js": "^11.9.0",
		"markdown-it": "^14.1.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@types/jsdom": "^28.0.1",
		"@types/markdown-it": "^14.1.2",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"eslint": "^8.57.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"typescript": "^5.4.0",
		"vite": "^5.2.0",
		"vitest": "^1.4.0"
	}
}
